# MoreLogin Local API
MORELOGIN_API_KEY=your_morelogin_api_key_here
MORELOGIN_PORT=40000

# Smartproxy
PROXY_SERVER=us.smartproxy.net
PROXY_PORT=3120
PROXY_PASSWORD=your_proxy_password_here
PROXY_PREFIX=your_proxy_prefix_here

# Backend
BACKEND_PORT=3100

# ━━━ Multi-Browser Provider Configuration ━━━

# Active browser provider (morelogin | multilogin; default: multilogin). Legacy: adspower → treated as multilogin in code.
BROWSER_PROVIDER=multilogin

# Multilogin X API credentials — list/create need all three set (no placeholders)
# Folder ID: Multilogin app → Profiles → folder right-click → copy folder UUID (multiloginx.com docs)
MULTILOGIN_EMAIL=your_multilogin_email@example.com
MULTILOGIN_PASSWORD=your_multilogin_password_here
MULTILOGIN_FOLDER_ID=your_workspace_folder_uuid_here
